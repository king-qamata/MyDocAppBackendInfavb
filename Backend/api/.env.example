# Database
DATABASE_URL="postgresql://mydocadmin:password@mydoc-postgres-prod.postgres.database.azure.com:5432/mydoc?schema=public"

# Redis
REDIS_HOST="mydoc-redis-prod.redis.cache.windows.net"
REDIS_PORT="6380"
REDIS_PASSWORD="your-redis-password"
REDIS_TLS="true"

# Azure Services
ACS_CONNECTION_STRING="endpoint=https://mydoc-acs-prod.communication.azure.com/;accesskey=your-key"
ACS_ENDPOINT="https://mydoc-acs-prod.communication.azure.com/"
STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=mydocstorageprod;AccountKey=your-key;EndpointSuffix=core.windows.net"

# Azure AI Services
AZURE_FACE_API_KEY="your-face-api-key"
AZURE_FACE_ENDPOINT="https://mydoc-face.cognitiveservices.azure.com/"
AZURE_SPEAKER_API_KEY="your-speaker-api-key"
AZURE_SPEAKER_ENDPOINT="https://mydoc-speaker.cognitiveservices.azure.com/"

# Azure AD B2C
B2C_TENANT_NAME="mydoc"
B2C_CLIENT_ID="your-client-id"
B2C_CLIENT_SECRET="your-client-secret"
B2C_POLICY_NAME="B2C_1A_SIGNUP_SIGNIN"

# Payment Providers
PAYSTACK_SECRET_KEY="sk_live_your-paystack-key"
PAYSTACK_PUBLIC_KEY="pk_live_your-paystack-key"
FLUTTERWAVE_SECRET_KEY="FLWSECK-live-your-key"
FLUTTERWAVE_WEBHOOK_HASH="your-flutterwave-webhook-hash"

# WebSocket/Real-time
WEB_PUBSUB_CONNECTION_STRING="Endpoint=https://mydoc.webpubsub.azure.com;AccessKey=your-key;Version=1.0;"

# Push Notifications
NOTIFICATION_HUB_CONNECTION_STRING="Endpoint=sb://mydoc.servicebus.windows.net/;SharedAccessKeyName=DefaultFullSharedAccessSignature;SharedAccessKey=your-key"
NOTIFICATION_HUB_NAME="mydoc-notifications-prod"

# Application
NODE_ENV="production"
PORT="3000"
API_BASE_URL="https://api.mydoc.ng"
CORS_ORIGIN="https://app.mydoc.ng"

# Encryption
ENCRYPTION_KEY="your-256-bit-key"
JWT_SECRET="your-jwt-secret"
JWT_ISSUER="mydoc-api"
JWT_AUDIENCE="mydoc-app"
DEV_BOOTSTRAP_KEY="dev-bootstrap-secret"
ACCESS_TOKEN_TTL_MINUTES="15"
REFRESH_TOKEN_TTL_DAYS="30"
REFRESH_TOKEN_SECRET="your-refresh-token-secret"

# ACS Webhooks
ACS_WEBHOOK_ALLOWED_TYPES="Microsoft.Communication.RecordingFileStatusUpdated,Microsoft.Communication.CallEnded"

# Monitoring
APPLICATIONINSIGHTS_CONNECTION_STRING="InstrumentationKey=your-key;IngestionEndpoint=https://your-region.in.applicationinsights.azure.com/"

# Feature Flags
ENABLE_RECORDING="true"
ENABLE_BIOMETRICS="true"
MAINTENANCE_MODE="false"

{
  "name": "mydoc-api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=20.15.0 <21",
    "npm": ">=10"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:status": "prisma migrate status",
    "test": "vitest run tests --exclude \"tests/**/*.js\"",
    "test:watch": "vitest tests --exclude \"tests/**/*.js\""
  },
  "dependencies": {
    "@azure/communication-chat": "^1.4.0",
    "@azure/communication-common": "^2.3.0",
    "@azure/communication-identity": "^1.3.1",
    "@azure/communication-network-traversal": "^1.1.0-beta.1",
    "@azure/identity": "^4.8.0",
    "@azure/notification-hubs": "^1.1.0",
    "@azure/storage-blob": "^12.26.0",
    "@azure/web-pubsub": "^1.0.2",
    "@prisma/client": "^5.22.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "applicationinsights": "^2.9.6",
    "axios": "^1.8.1",
    "bcrypt": "^5.1.1",
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.5.0",
    "jsonwebtoken": "^9.0.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.8",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
